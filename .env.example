# ── Required ────────────────────────────────────────────────────────────────
# MySQL / PlanetScale / TiDB connection string (mysql2 format)
DATABASE_URL=mysql://user:password@host:3306/ambassador_db

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=changeme-use-openssl-rand-hex-32

# Telegram bot token (from @BotFather) — used for Login Widget HMAC
TELEGRAM_BOT_TOKEN=

# ── Auth (OAuth provider) ────────────────────────────────────────────────────
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
# Comma-separated admin emails auto-promoted on first login
ADMIN_EMAILS=admin@your-domain.com

# ── LLM / AI providers (all optional) ───────────────────────────────────────
# OpenAI-compatible base URL for the built-in LLM proxy
LLM_API_BASE_URL=https://api.openai.com
LLM_API_KEY=sk-...

# OpenRouter (text + image generation)
OPENROUTER_API_KEY=

# fal.ai (video and image generation)
FAL_API_KEY=

# ── X / Twitter scraping ────────────────────────────────────────────────────
APIFY_API_KEY=
# Default actor: apidojo/tweet-scraper (61RPP7dywgiy0JPD0)
SCRAPER_ACTOR_ID=
SCRAPER_UNLIMITED_ACTOR_ID=

# ── Brand / program config ───────────────────────────────────────────────────
# Comma-separated X handles for official-account scraping (Pipeline 2 & 3)
BRAND_OFFICIAL_HANDLES=myprotocol,myfounder

# Comma-separated brand keywords for tweet relevance filtering
BRAND_KEYWORDS=#mybrand,myprotocol,myprotocol.xyz

# Single word for word-boundary regex filtering
BRAND_WORD_FILTER=MyProtocol

# Earliest date to scrape posts from (YYYY-MM-DD)
PROGRAM_START_DATE=2025-01-01

# CDN base URL for badge/logo assets (no trailing slash)
VITE_CDN_BASE=https://cdn.example.com/ambassador-kit/assets

# Secret for /api/internal/run-daily endpoint (used by cron/scheduler)
SCRAPE_SECRET=changeme-use-openssl-rand-hex-32

# ── App config ────────────────────────────────────────────────────────────────
# Public base URL of the deployed app (used for webhook callbacks)
VITE_APP_BASE_URL=https://your-app.example.com
VITE_APP_DOMAIN=your-app.example.com
APP_BASE_URL=https://your-app.example.com
APP_NAME=Ambassador Studio

# NachoNacho (optional — for marketplace perks tab)
NACHONACHO_API_KEY=

# CSV export path for audit scripts
EXPORT_CSV_PATH=./all_posts.csv

# ── UI / meta ─────────────────────────────────────────────────────────────────
# App name shown in <title>, OG tags, and nav
VITE_APP_NAME=Ambassador Studio
# Short description for OG/Twitter meta tags
VITE_APP_DESCRIPTION=Join the ambassador program, earn XP, climb the leaderboard.
# Canonical public URL (no trailing slash)
VITE_APP_URL=https://your-app.example.com
# OG image URL (1200x630 recommended)
VITE_OG_IMAGE=https://cdn.example.com/ambassador-kit/assets/og.png

# ── Google Maps (optional) ────────────────────────────────────────────────────
# Required only if you use the MapView component (client/src/components/Map.tsx).
# VITE_MAPS_API_KEY: your Google Maps API key (restricted to your domain).
# VITE_MAPS_PROXY_URL: base URL of your Maps proxy server (no trailing slash).
#   The proxy appends /maps/api/js?key=... — this keeps the key server-side.
VITE_MAPS_API_KEY=
VITE_MAPS_PROXY_URL=https://maps-proxy.example.com

# ── Optional analytics (Umami) ───────────────────────────────────────────────
# Remove the <script> in index.html to disable analytics entirely
VITE_ANALYTICS_ENDPOINT=https://analytics.your-domain.com
VITE_ANALYTICS_WEBSITE_ID=

# ── Evangelist section copy (optional) ───────────────────────────────────────
VITE_EVANGELIST_EVENT=Program summit — invite-only
